# =============================================================================
# Aletheia — Environment Variables Template
# Copy file này thành .env và điền giá trị thật
# cp .env.example .env
# =============================================================================

# ── EAS / Expo ───────────────────────────────────────────────────────────────
# Lấy từ: npx eas project:init
EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Username trên expo.dev
EXPO_PUBLIC_OWNER_NAME=your-expo-username

# ── OAuth (chỉ cần khi dùng Manus auth server) ───────────────────────────────
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
EXPO_PUBLIC_APP_ID=
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_API_BASE_URL=

# ── AI Provider Keys (SERVER-SIDE ONLY) ──────────────────────────────────────
# QUAN TRỌNG: Không dùng prefix EXPO_PUBLIC_ cho các keys này.
# Keys này chỉ được đọc bởi Express server (server/_core/index.ts).
# Không bao giờ expose ra client bundle.
# Xem: docs/BLUEPRINT.md → Security section
ALETHEIA_CLAUDE_API_KEY=sk-ant-api03-...
ALETHEIA_OPENAI_API_KEY=sk-proj-...
ALETHEIA_GEMINI_API_KEY=AIza...

# ── Gift Backend (Cloudflare Workers) ────────────────────────────────────────
# URL của CF Worker đã deploy (xem gift-backend/)
EXPO_PUBLIC_GIFT_BACKEND_URL=https://your-worker.your-subdomain.workers.dev

# ── RevenueCat ───────────────────────────────────────────────────────────────
# Lấy từ app.revenuecat.com → Project → API Keys
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...

# ── Development overrides ────────────────────────────────────────────────────
# Port Metro bundler (default: 8081)
# EXPO_PORT=8081

# =============================================================================
# KHÔNG commit file .env vào git.
# .env đã có trong .gitignore.
# =============================================================================
