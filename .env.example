# ============================================================================
# Aletheia beta environment template
# Copy to `.env` and replace placeholder values before running a beta build.
# System-injected env still overrides `.env` via `scripts/load-env.js`.
# ============================================================================

# ----------------------------------------------------------------------------
# Expo / release identity
# Required for real EAS beta builds.
# ----------------------------------------------------------------------------
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id
EXPO_PUBLIC_OWNER_NAME=your-expo-owner

# ----------------------------------------------------------------------------
# Shared auth / app routing
# Required when real auth/backend surfaces are enabled.
# ----------------------------------------------------------------------------
APP_ID=aletheia-beta
EXPO_PUBLIC_APP_ID=aletheia-beta
OAUTH_SERVER_URL=https://auth.example.com
EXPO_PUBLIC_OAUTH_SERVER_URL=https://auth.example.com
OAUTH_PORTAL_URL=https://portal.example.com
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://portal.example.com
OWNER_OPEN_ID=owner-open-id
EXPO_PUBLIC_OWNER_OPEN_ID=owner-open-id
JWT_SECRET=replace-with-a-long-random-secret

# ----------------------------------------------------------------------------
# Backend / API routing
# Required for real beta unless you intentionally ship local-only fallback.
# ----------------------------------------------------------------------------
API_BASE_URL=https://api.example.com
EXPO_PUBLIC_API_BASE_URL=https://api.example.com
AI_API_URL=https://ai.example.com

# Optional direct Forge surface if your backend proxies through it.
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
AI_API_KEY=

# Optional provider keys for server-side experiments or transitional flows.
OPENAI_API_KEY=
ALETHEIA_OPENAI_API_KEY=
GEMINI_API_KEY=
ALETHEIA_GEMINI_API_KEY=

# ----------------------------------------------------------------------------
# Telemetry
# Sentry is treated as required for beta release readiness.
# PostHog is recommended but non-blocking.
# ----------------------------------------------------------------------------
EXPO_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
EXPO_PUBLIC_POSTHOG_API_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ----------------------------------------------------------------------------
# Optional product surfaces
# ----------------------------------------------------------------------------
EXPO_PUBLIC_GIFT_BACKEND_URL=
LOCAL_AI_URL=
LOCAL_AI_MODEL=
OLLAMA_BASE_URL=
OLLAMA_MODEL=
INTERPRETATION_CLOUD_PROVIDER=
INTERPRETATION_CLOUD_MODEL=
CLOUD_AI_PROVIDER=
CLOUD_AI_MODEL=
