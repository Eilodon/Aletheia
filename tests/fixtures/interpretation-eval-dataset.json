{
  "version": "1.0.0",
  "created_at": "2026-04-11",
  "description": "Evaluation dataset for AI interpretation output contract. Used to validate local and cloud model outputs against the Aletheia interpretation rubric.",
  "output_contract": {
    "language_fidelity": "Response language must match passage language (vi/en)",
    "length_constraint": "Main reflection: 80-120 words",
    "situation_mirroring": "When user shares situation, mirror their language without paraphrasing",
    "no_direct_advice": "Never use 'b nên...' or 'you should...'",
    "no_future_prediction": "Never predict outcomes or make definitive future statements",
    "ending_question": "Final line must be one short open question (< 15 words), in italics format: *[question]*"
  },
  "rubric": {
    "language_fidelity": {
      "weight": 1.0,
      "pass_criteria": "Response language matches source_language exactly",
      "fail_examples": ["Vietnamese response for English passage", "Mixed language without context"]
    },
    "tone_fidelity": {
      "weight": 1.0,
      "pass_criteria": "Warm, contemplative, non-judgmental tone appropriate to user_intent",
      "fail_examples": ["Clinical/detached tone", "Preachy or lecturing tone", "Overly casual tone"]
    },
    "non_advice_compliance": {
      "weight": 1.5,
      "pass_criteria": "No prescriptive statements telling user what to do",
      "fail_examples": ["B nên...", "You should...", "Try to...", "Make sure you..."]
    },
    "ending_question_compliance": {
      "weight": 1.0,
      "pass_criteria": "Final line is a single open question < 15 words, in italics, about present moment",
      "fail_examples": ["No question at end", "Multiple questions", "Question about future", "Question not in italics"]
    },
    "length_compliance": {
      "weight": 0.5,
      "pass_criteria": "Main reflection between 80-120 words (excluding question)",
      "fail_examples": ["Under 50 words", "Over 150 words"]
    },
    "situation_mirroring": {
      "weight": 1.0,
      "pass_criteria": "When situation_text provided, uses user's own words naturally without mechanical repetition",
      "fail_examples": ["Ignores situation completely", "Paraphrases instead of mirroring", "Repeats situation verbatim"]
    }
  },
