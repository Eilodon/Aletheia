{
  "expo": {
    "name": "Aletheia",
    "icon": "./assets/images/android-icon-foreground.png",
    "version": "1.0.0",
    "platforms": ["ios", "android"],
    "primaryColor": "#6366F1",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1F2937"
    },
    "ios": {
      "bundleIdentifier": "app.aletheia.mirror",
      "buildNumber": "1",
      "appStoreUrl": "https://apps.apple.com/app/aletheia-mirror",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Aletheia cần quyền camera để chụp ảnh chia sẻ",
        "NSPhotoLibraryUsageDescription": "Aletheia cần quyền ảnh để lưu ảnh chia sẻ"
      }
    },
    "android": {
      "package": "app.aletheia.mirror",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.SCHEDULE_EXACT_ALARM"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "aletheia-mirror"
      }
    }
  }
}
